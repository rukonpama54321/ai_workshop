# --- Core ---
DATABASE_URL=postgresql://medclaim:medclaim@localhost:5432/medclaim
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=workshop-dev-secret
UPLOAD_DIR=uploads
SAP_USE_MOCK=true
FRONTEND_URL=http://127.0.0.1:5173

# --- LLM ---
# Local self-hosted (default): keeps data on your machine/network.
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2
# Free hosted demo: set LLM_PROVIDER=groq and add a key from https://console.groq.com
# LLM_PROVIDER=groq
# LLM_API_KEY=gsk_xxx
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Email notifications ---
# none (default) | resend
EMAIL_PROVIDER=none
# RESEND_API_KEY=re_xxx        # from https://resend.com (free tier)
# EMAIL_FROM=onboarding@resend.dev
